# ============================================
# YW-EIMS Docker 环境变量配置
# 部署前复制此文件为 .env 并填入真实值
# cp .env.example .env
# ============================================

# PostgreSQL 数据库
POSTGRES_DB=eims
POSTGRES_USER=change_me
POSTGRES_PASSWORD=change_me

# 后端数据库连接
DATABASE_URL=postgresql://change_me:change_me@postgres:5432/eims?schema=public

# JWT 密钥（生产环境请使用随机字符串）
JWT_SECRET=change_me_to_random_string
JWT_EXPIRES_IN=2h
JWT_REFRESH_SECRET=change_me_to_random_string
JWT_REFRESH_EXPIRES_IN=7d

# 前端端口
APP_PORT=8003
