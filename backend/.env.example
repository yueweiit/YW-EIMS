NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/eims?schema=public
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=2h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ERP (YonSuite)
ERP_APP_KEY=your-erp-app-key
ERP_APP_SECRET=your-erp-app-secret

# DingTalk
DINGTALK_APP_KEY=your-dingtalk-app-key
DINGTALK_APP_SECRET=your-dingtalk-app-secret

# DingTalk user OAuth login (must be configured in the DingTalk app callback settings)
DINGTALK_OAUTH_CLIENT_ID=your-dingtalk-oauth-client-id
DINGTALK_OAUTH_CLIENT_SECRET=your-dingtalk-oauth-client-secret
DINGTALK_OAUTH_REDIRECT_URI=https://eims.example.com/api/auth/dingtalk/callback
DINGTALK_OAUTH_SCOPES=openid
EIMS_FRONTEND_URL=https://eims.example.com

# DingTalk OA Database (for syncing employees, departments, approval mappings)
DINGTALK_OA_DB_URL=postgresql://postgres:postgres@localhost:5432/dingtalk_oa

# ERPNext
ERPNEXT_AUTH_TOKEN=your-erpnext-token
ERPNEXT_ITEM_API_URL=http://deeplinkerp.com/api/resource/Item
