generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "material"]
}

model User {
  id         Int      @id @default(autoincrement())
  userName   String   @unique @map("user_name")
  password   String
  realName   String?  @map("real_name")
  roles      String[] @default([])
  buttons    String[] @default([])
  status     String   @default("1")
  createBy   String   @default("system") @map("create_by")
  createTime DateTime @default(now()) @map("create_time")
  updateBy   String?  @map("update_by")
  updateTime DateTime @updatedAt @map("update_time")

  @@schema("public")
  @@map("system_user")
}

/// 物料申请主数据表（存储所有物料申请记录）
model Material {
  id             Int       @id @default(autoincrement())
  applicant      String    @db.VarChar(50)
  applicationDate DateTime? @default(now()) @db.Date @map("application_date")
  materialName   String    @db.VarChar(500) @map("material_name")
  specifications String?   @db.VarChar(1000)
  unit           String?   @db.VarChar(20)
  code           String?   @unique @db.VarChar(50)
  codePrefix     String?   @db.VarChar(10) @map("code_prefix")
  explainContent String?   @db.VarChar(100) @map("explain_content")
  unitCode       String?   @db.VarChar(3) @map("unit_code")
  unitRef        Unit?     @relation(fields: [unitCode], references: [unitCode], onDelete: SetNull, onUpdate: Cascade)

  @@index([applicant])
  @@index([applicationDate])
  @@index([codePrefix])
  @@index([unitCode])
  @@index([materialName])
  @@schema("material")
  @@map("materials")
}

/// 存储单位编码与名称的映射表，编码统一为两位数格式（个位数补零）
model Unit {
  unitCode  String     @id @db.VarChar(3) @map("unit_code")
  unit      String     @unique @db.VarChar(50)
  materials Material[]

  @@schema("material")
  @@map("units")
}

/// 编码前缀字典表（存储字母前缀及对应含义）
model MaterialCodeRule {
  codePrefix     String @id @db.VarChar(10) @map("code_prefix")
  explainContent String @db.VarChar(100) @map("explain_content")

  @@schema("material")
  @@map("material_code_rules")
}
