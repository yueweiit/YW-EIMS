generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "material", "mold", "oa"]
}

model User {
  id         Int      @id @default(autoincrement())
  userName   String   @unique @map("user_name")
  password   String
  realName   String?  @map("real_name")
  roles      String[] @default([])
  buttons    String[] @default([])
  status     String   @default("1")
  createBy   String   @default("system") @map("create_by")
  createTime DateTime @default(now()) @map("create_time")
  updateBy   String?  @map("update_by")
  updateTime DateTime @updatedAt @map("update_time")

  @@map("system_user")
  @@schema("public")
}

/// 物料申请主数据表（存储所有物料申请记录）
model Material {
  id              Int       @id @default(autoincrement())
  applicant       String    @db.VarChar(50)
  applicationDate DateTime? @default(now()) @map("application_date") @db.Date
  materialName    String    @map("material_name") @db.VarChar(500)
  specifications  String?   @db.VarChar(1000)
  unit            String?   @db.VarChar(20)
  code            String?   @unique @db.VarChar(50)
  codePrefix      String?   @map("code_prefix") @db.VarChar(10)
  explainContent  String?   @map("explain_content") @db.VarChar(100)
  unitCode        String?   @map("unit_code") @db.VarChar(3)
  unitRef         Unit?     @relation(fields: [unitCode], references: [unitCode], onDelete: SetNull, onUpdate: Cascade)

  @@index([applicant])
  @@index([applicationDate])
  @@index([codePrefix])
  @@index([unitCode])
  @@index([materialName])
  @@map("materials")
  @@schema("material")
}

/// 存储单位编码与名称的映射表，编码统一为两位数格式（个位数补零）
model Unit {
  unitCode  String     @id @map("unit_code") @db.VarChar(3)
  unit      String     @unique @db.VarChar(50)
  materials Material[]

  @@map("units")
  @@schema("material")
}

/// 编码前缀字典表（存储字母前缀及对应含义）
model MaterialCodeRule {
  codePrefix     String  @id @map("code_prefix") @db.VarChar(10)
  explainContent String  @map("explain_content") @db.VarChar(100)
  prefixLength   Int?    @map("prefix_length")

  @@map("material_code_rules")
  @@schema("material")
}

// ============ MOLD SCHEMA ============

/// 手机编码序列表（保证 phoneCode 并发安全生成）
model PhoneCodeSequence {
  id           Int @id @default(autoincrement())
  currentValue Int @default(0) @map("current_value")

  @@map("phone_code_sequence")
  @@schema("mold")
}

/// 手机型号表
model PhoneModel {
  id             Int     @id @default(autoincrement())
  phoneCode      String  @unique @map("phone_code") @db.VarChar(20)
  phoneName      String  @unique @map("phone_name") @db.VarChar(200)
  phoneShortName String? @map("phone_short_name") @db.VarChar(200)

  @@index([phoneName])
  @@map("phone_models")
  @@schema("mold")
}

/// 颜色表
model Color {
  id        Int    @id @default(autoincrement())
  colorCode String @unique @map("color_code") @db.VarChar(10)
  colorName String @map("color_name") @db.VarChar(100)

  @@map("colors")
  @@schema("mold")
}

/// 材质表
model MoldMaterial {
  id       Int    @id @default(autoincrement())
  typeCode String @unique @map("type_code") @db.VarChar(10)
  typeName String @map("type_name") @db.VarChar(50)

  @@map("type")
  @@schema("mold")
}

/// 模具编码表（一个 moldType 可对应多条记录）
model MoldCode {
  id         Int    @id @default(autoincrement())
  moldCode   String @unique @map("mold_code") @db.VarChar(30)
  moldType   String @map("mold_type") @db.VarChar(100)
  moldName   String @map("mold_name") @db.VarChar(200)
  moldPrefix String @map("mold_prefix") @db.VarChar(20)
  typeName   String @map("type_name") @db.VarChar(50)
  typeCode   String @map("type_code") @db.VarChar(10)

  @@index([moldType])
  @@map("mold_codes")
  @@schema("mold")
}

/// 模具表（品目主数据）
model Mold {
  id        Int    @id @default(autoincrement())
  moldType  String @map("mold_type") @db.VarChar(100)
  moldName  String @map("mold_name") @db.VarChar(200)
  moldCode  String @map("mold_code") @db.VarChar(30)
  phoneName String @map("phone_name") @db.VarChar(200)
  phoneCode String @map("phone_code") @db.VarChar(20)
  typeCode  String @map("type_code") @db.VarChar(10)
  typeName  String @map("type_name") @db.VarChar(50)
  itemCode  String @unique @map("item_code") @db.VarChar(50)

  @@unique([moldCode, phoneCode])
  @@index([moldCode])
  @@index([phoneCode])
  @@map("molds")
  @@schema("mold")
}

/// 产品编码表
model ProductCode {
  id          Int    @id @default(autoincrement())
  productCode String @unique @map("product_code") @db.VarChar(20)
  productType String @map("product_type") @db.VarChar(100)
  productName String @map("product_name") @db.VarChar(200)
  colorName   String @map("color_name") @db.VarChar(100)
  colorCode   String @map("color_code") @db.VarChar(10)

  @@index([productType])
  @@map("product_codes")
  @@schema("mold")
}

/// 产品表（品目主数据）
model Product {
  id             Int    @id @default(autoincrement())
  productType    String @map("product_type") @db.VarChar(100)
  productName    String @map("product_name") @db.VarChar(200)
  productCode    String @map("product_code") @db.VarChar(20)
  phoneShortName String @map("phone_short_name") @db.VarChar(200)
  phoneCode      String @map("phone_code") @db.VarChar(20)
  colorName      String @map("color_name") @db.VarChar(100)
  colorCode      String @map("color_code") @db.VarChar(10)
  itemCode       String @unique @map("item_code") @db.VarChar(50)

  @@unique([productCode, phoneCode, colorCode])
  @@index([productCode])
  @@index([phoneCode])
  @@index([colorCode])
  @@map("products")
  @@schema("mold")
}

// ============ OA SCHEMA ============

/// OA审批编号与钉钉实例ID映射缓存表
model OaMapping {
  oaCode          String    @id @map("oa_code") @db.VarChar(100)
  instanceId      String    @map("instance_id") @db.VarChar(100)
  processCode     String?   @map("process_code") @db.VarChar(100)
  formName        String?   @map("form_name") @db.VarChar(255)
  dingCreateTime  DateTime? @map("ding_create_time")
  updateTime      DateTime? @default(now()) @map("update_time") @db.Timestamp()

  @@map("oa_mapping")
  @@schema("oa")
}

/// 钉钉员工表
model DingEmployee {
  dingUserid String  @id @map("ding_userid") @db.VarChar(100)
  empName    String? @map("emp_name") @db.VarChar(200)
  deptId     Int?    @map("dept_id")
  title      String? @db.VarChar(200)
  isBoss     String? @map("is_boss") @db.VarChar(10)

  @@map("ding_employee")
  @@schema("oa")
}

/// 钉钉部门表
model DingDepartment {
  deptId        Int     @id @map("dept_id")
  deptName      String? @map("dept_name") @db.VarChar(200)
  parentDeptId  Int?    @map("parent_dept_id")

  @@map("ding_department")
  @@schema("oa")
}

/// ERP供应商缓存表
model ErpSupplier {
  code       String    @id @db.VarChar(100)
  name       String?   @db.VarChar(255)
  updateTime DateTime? @default(now()) @map("update_time") @db.Timestamp()

  @@map("erp_supplier")
  @@schema("oa")
}

/// ERP物料缓存表
model ErpMaterial {
  code          String    @id @db.VarChar(100)
  name          String?   @db.VarChar(255)
  specification String?   @db.VarChar(500)
  updateTime    DateTime? @default(now()) @map("update_time") @db.Timestamp()

  @@map("erp_material")
  @@schema("oa")
}

/// ERP计量单位缓存表
model ErpUnit {
  code       String    @id @db.VarChar(100)
  name       String?   @db.VarChar(255)
  updateTime DateTime? @default(now()) @map("update_time") @db.Timestamp()

  @@map("erp_unit")
  @@schema("oa")
}

/// ERP税率缓存表
model ErpTax {
  code       String    @id @db.VarChar(100)
  name       String?   @db.VarChar(255)
  rateValue  Decimal?  @map("rate_value") @db.Decimal(10, 4)
  updateTime DateTime? @default(now()) @map("update_time") @db.Timestamp()

  @@map("erp_tax")
  @@schema("oa")
}
